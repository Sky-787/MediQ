{
  "name": "mediq-backend",
  "version": "1.0.0",
  "description": "Backend para MediQ",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "start:e2e": "node src/server.e2e.js",
    "test": "node ./node_modules/jest/bin/jest.js --runInBand",
    "test:coverage": "node ./node_modules/jest/bin/jest.js --runInBand --coverage",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "seed": "node src/seeds/index.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 60000,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js",
      "!src/swagger.js",
      "!src/config/db.js",
      "!src/seeds/**/*.js",
      "!src/controllers/auth.controller.js"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-plugin-jest": "^29.15.2",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.4.3",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
