# ================================
# MediQ Backend — Variables de entorno
# Copia este archivo como .env y completa los valores
# NUNCA subas el .env real al repositorio
# ================================

# Entorno: development | production | test
NODE_ENV=development

# Puerto del servidor
PORT=5000

# Conexión a MongoDB
MONGODB_URI=mongodb://localhost:27017/mediq

# JWT — usa una clave larga y aleatoria en producción
JWT_SECRET=cambia_esto_por_un_secreto_seguro
JWT_EXPIRES_IN=7d

# Cookie
COOKIE_NAME=token
COOKIE_MAX_AGE=604800000

# CORS — origen permitido del frontend
CORS_ORIGIN=http://localhost:5173